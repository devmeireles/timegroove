# react-simple-maps still declares peer deps for React 16/17/18 only, so
# strict resolution (npm 7+'s default) refuses to install with React 19.
# Apply legacy-peer-deps globally so local installs and Vercel's build use
# the same resolution policy. Without this, `npm install` on Vercel fails
# the build before TypeScript ever runs.
legacy-peer-deps=true
